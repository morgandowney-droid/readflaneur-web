# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Broker outreach lists contain PII (broker names, emails, phone numbers) and
# should never be committed. Sample schema + research prompt + neighborhood
# list (public data) are checked in.
/outreach/*
!/outreach/targets.sample.csv
!/outreach/.gitkeep
!/outreach/broker-research-prompt.md
!/outreach/flaneur-neighborhoods.csv

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Sentry Config File
.env.sentry-build-plugin

# Manual image uploads (processed and uploaded to Supabase, not needed in git)
/manual-images/

# Personal correspondence drafts
will-lewis-email.txt
